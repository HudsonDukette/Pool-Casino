# Example env for artifacts/api-server — DO NOT COMMIT SECRETS
# Copy this to .env locally or add variables in Railway (Project → Variables)

# Postgres (Neon) — used by @workspace/db
# Example Neon pooled runtime URL (set this in Railway as DATABASE_URL)
# DO NOT COMMIT SECRETS. Replace the value below with your Neon pooled URL.
DATABASE_URL=postgresql://neondb_owner:npg_ZcWSj5ezy9Qs@ep-purple-grass-ambpmgvb-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_SSL=true

# Session secret for express-session
SESSION_SECRET=change-me-to-a-long-random-string

# Server port
PORT=8080

# CORS / Allowed origin (set to your frontend URL in production)
ALLOWED_ORIGIN=https://pool-casino.vercel.app

# Logging
LOG_LEVEL=info
# PoolCasino API Server — environment variables
# Copy this file to .env and fill in the values.

# ── Database (PostgreSQL via Drizzle ORM) ─────────────────────────────────────
# Supabase: go to Project Settings → Database → Connection string → URI
# Use the "Transaction" pooler on port 6543 for Railway (serverless-safe).
# Example: postgresql://postgres.xxxxx:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://user:hudsonparkerdukette@host:5432/dbname

# Set to "true" when the DB requires TLS (Supabase always does).
DATABASE_SSL=true

# If you previously used Supabase client features (Auth/Storage/Realtime), they
# are not configured here. This project now connects directly to Neon Postgres
# via `DATABASE_URL` and uses Drizzle/@workspace/db. Remove Supabase-specific
# env vars and libraries unless you intentionally add them back.

# ── Sessions ──────────────────────────────────────────────────────────────────
# Long random string used to sign session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Exact origin of your Vercel frontend (no trailing slash).
# Example: https://poolcasino.vercel.app
ALLOWED_ORIGIN=https://pool-casino.vercel.app

# ── Push Notifications (optional) ────────────────────────────────────────────
# Generate VAPID keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
