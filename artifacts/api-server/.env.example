# PoolCasino API Server — environment variables
# Copy this file to .env and fill in the values.

# ── Database (PostgreSQL via Drizzle ORM) ─────────────────────────────────────
# Supabase: go to Project Settings → Database → Connection string → URI
# Use the "Transaction" pooler on port 6543 for Railway (serverless-safe).
# Example: postgresql://postgres.xxxxx:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set to "true" when the DB requires TLS (Supabase always does).
DATABASE_SSL=true

# ── Supabase JS Client (optional — for Auth / Storage / Realtime) ─────────────
# Project URL (Project Settings → API → Project URL)
SUPABASE_URL=https://envkswuvdssykdiftycs.supabase.co
# Service Role key — Project Settings → API → service_role (keep secret!)
# The anon/publishable key works too but has limited RLS-restricted access.
SUPABASE_SERVICE_ROLE_KEY=
# Fallback public key (safe to expose, used if SERVICE_ROLE_KEY is absent)
SUPABASE_ANON_KEY=sb_publishable_2us86ssyzMHL1_gEFa7pIQ_8TFNhXs0

# ── Sessions ──────────────────────────────────────────────────────────────────
# Long random string used to sign session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Exact origin of your Vercel frontend (no trailing slash).
# Example: https://poolcasino.vercel.app
ALLOWED_ORIGIN=https://your-frontend.vercel.app

# ── Push Notifications (optional) ────────────────────────────────────────────
# Generate VAPID keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
