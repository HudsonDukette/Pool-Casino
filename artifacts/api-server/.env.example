# PoolCasino API Server — environment variables
# Copy this file to .env and fill in the values.

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# For Supabase: use the "Connection pooling" URI (Transaction mode, port 6543).
# Append ?pgbouncer=true to the URI when using Supabase pooler.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set to "true" when the DB requires TLS (Supabase always does).
DATABASE_SSL=true

# ── Sessions ──────────────────────────────────────────────────────────────────
# Long random string used to sign session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Exact origin of your Vercel frontend (no trailing slash).
# Example: https://poolcasino.vercel.app
ALLOWED_ORIGIN=https://your-frontend.vercel.app

# ── Push Notifications (optional) ────────────────────────────────────────────
# Generate VAPID keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
