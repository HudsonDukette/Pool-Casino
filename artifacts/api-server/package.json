    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "^0.45.1",
    "express": "^5",
    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "pino": "^9",
    "pino-http": "^10",
    "socket.io": "^4.8.3",
    "web-push": "^3.6.7"
