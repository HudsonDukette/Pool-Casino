# PoolCasino Frontend — environment variables
# Copy this file to .env and fill in the values.
# On Vercel, set these as Environment Variables in the project settings.

# ── API Backend URL ───────────────────────────────────────────────────────────
# Full URL of your Railway API server (no trailing slash).
# Example: https://poolcasino-api.up.railway.app
# Leave empty when running locally via Replit (uses same-origin proxy).
VITE_API_URL=https://your-api.up.railway.app
